DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
SWAGGER_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
FRONTEND_URL=http://localhost:3000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_URL=http://localhost:3000/storage
FOOTBALL_DATA_TOKEN=
VITE_API_BASE_URL=

# --- Production (VPS) only. See application-prod.properties + docker-compose.prod.yml ---
# SPRING_PROFILES_ACTIVE=prod
# DOMAIN=demo.duckdns.org            # your public domain (Caddy issues TLS for it)
# ACME_EMAIL=you@example.com         # Let's Encrypt contact
# BEHIND_PROXY=true                  # trust X-Forwarded-For from Caddy
# DDL_AUTO=validate                  # first empty-DB boot: set to 'update' once, then remove
# In prod set these to your domain (same-origin, so CORS is mostly moot but keep it tight):
#   CORS_ALLOWED_ORIGINS=https://demo.duckdns.org
#   MINIO_PUBLIC_URL=https://demo.duckdns.org/storage
#   FRONTEND_URL=https://demo.duckdns.org      # used in verification/reset e-mails
#   VITE_API_BASE_URL=                          # leave EMPTY -> axios uses window.location.origin
